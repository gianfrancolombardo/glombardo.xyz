---
import { PROJECTS } from "../../constants";
import ProjectCard from "./ProjectCard";
---

<section id="work" class="py-32 bg-slate-950 relative">
    <div class="max-w-7xl mx-auto px-6">
        <div
            class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6"
        >
            <div>
                <h2
                    class="font-display text-4xl md:text-5xl font-bold text-slate-100 mb-4 tracking-tight"
                >
                    Selected <span class="text-brand-accent">Works</span>
                </h2>
                <p class="text-slate-400 max-w-xl text-lg">
                    Evidence of impact. From high-scale architecture to
                    generative AI experiments.
                </p>
            </div>
            <a
                href="https://github.com/gianfrancolombardo"
                target="_blank"
                rel="noopener noreferrer"
                class="hidden md:flex items-center gap-2 text-slate-300 hover:text-brand-accent transition-colors font-mono text-sm tracking-wider"
            >
                // VIEW_GITHUB_PROFILE
            </a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 perspective-1000">
            {
                PROJECTS.map((project) => (
                    <ProjectCard client:visible project={project} />
                ))
            }
        </div>
    </div>
</section>
