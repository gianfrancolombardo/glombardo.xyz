---
import Timeline from "./Timeline";
---

<section id="experience" class="py-32 bg-brand-900 relative">
    <div class="max-w-7xl mx-auto px-6">
        <div class="mb-24 md:text-center">
            <h2
                class="font-display text-4xl md:text-5xl font-bold text-slate-100 mb-6 tracking-tight"
            >
                Career <span class="text-brand-accent">Data Stream</span>
            </h2>
            <p class="text-slate-400 max-w-2xl mx-auto text-lg leading-relaxed">
                A chronicled execution of technical leadership and system
                architecture.
            </p>
        </div>

        <Timeline client:only="react" />
    </div>
</section>
