---
import { SOCIALS } from "../../constants";
import ContactForm from "./ContactForm";
import { Copy } from "lucide-react";
---

<footer id="contact" class="bg-brand-900 pt-32 pb-12 relative overflow-hidden">
    {/* Background Glow */}
    <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-brand-500/10 blur-[120px] rounded-full pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 mb-24">
            <div>
                <h2
                    class="font-display text-5xl md:text-7xl font-bold text-slate-100 mb-8 leading-tight"
                >
                    Ready to <br /><span class="text-brand-accent"
                        >Architect?</span
                    >
                </h2>
                <p
                    class="text-slate-400 text-lg mb-12 max-w-md leading-relaxed"
                >
                    Open for high-impact technical leadership roles and complex
                    System Design challenges.
                </p>

                <div class="flex gap-4">
                    {
                        SOCIALS.map((social) => (
                            <a
                                href={social.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="w-14 h-14 rounded-full border border-slate-700 bg-slate-800/50 flex items-center justify-center text-slate-400 hover:text-brand-accent hover:border-brand-accent hover:bg-slate-800 hover:scale-110 transition-all duration-300 backdrop-blur-sm"
                                aria-label={social.platform}
                            >
                                <social.icon className="w-6 h-6" />
                            </a>
                        ))
                    }
                </div>
            </div>

            <div>
                <ContactForm client:visible />
            </div>
        </div>

        <div
            class="pt-8 border-t border-slate-800/50 flex flex-col md:flex-row justify-between items-center gap-4 text-sm font-mono text-slate-600"
        >
            <p>
                © {new Date().getFullYear()} Gianfranco Lombardo.
            </p>
            <p class="flex items-center gap-2">
                SYSTEM_STATUS: <span class="text-green-500">OPTIMAL</span>
            </p>
        </div>
    </div>
</footer>
